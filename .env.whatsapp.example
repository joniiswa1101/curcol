# WhatsApp Business API Credentials
# Get these values from: https://business.facebook.com

# 1. Your WhatsApp API Access Token
# How to get: 
#   - Go to business.facebook.com > Your App > WhatsApp Settings > API Access Token
#   - Copy the long string (starts with EAAX or similar)
WHATSAPP_API_TOKEN=your_api_token_here

# 2. Your WhatsApp Phone Number ID
# How to get:
#   - Go to WhatsApp Settings > Phone Numbers
#   - Find your registered phone number
#   - Copy the ID (looks like: 102012345678901)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# 3. Webhook Verify Token (you create this)
# How to set:
#   - Create any random string (e.g., "my_webhook_secret_xyz")
#   - Use this in your Meta Webhook Settings
#   - MUST match what you set in Meta Business App
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
